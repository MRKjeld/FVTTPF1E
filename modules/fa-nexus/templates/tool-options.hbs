                                   max="{{control.strengthMax}}"
                                   step="{{control.strengthStep}}"
                                   value="{{control.strength}}"
                                   aria-label="{{control.strengthAriaLabel}}"
                                   data-fa-nexus-scalar-strength-slider="{{control.id}}"
                                   {{#unless control.randomEnabled}}disabled{{/unless}}>
                            <input type="number"
                                   class="fa-nexus-scalar-randomized__strength-value"
                                   min="{{control.strengthMin}}"
                                   max="{{control.strengthMax}}"
                                   step="{{control.strengthStep}}"
                                   value="{{control.strength}}"
                                   inputmode="decimal"
                                   data-fa-nexus-scalar-strength-display="{{control.id}}"
                                   title="{{control.strengthDisplay}}"
                                   {{#unless control.randomEnabled}}disabled{{/unless}}>
                        </div>
                      {{/unless}}
                    {{/if}}
                  </div>
                {{/if}}

                {{#if (eq control.type "drop-shadow")}}
                  {{> faNexusToolOptionsDropShadow control=control}}
                {{/if}}

                {{#if (eq control.type "portal-controls")}}
                  {{> faNexusToolOptionsPortalControls control=control}}
                {{/if}}
              {{/each}}
            </div>
          </section>
        {{/each}}
      {{else}}
