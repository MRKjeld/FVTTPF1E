                                   data-fa-nexus-scalar-random-min-slider="{{control.id}}"
                                   {{#if control.disabled}}disabled{{/if}}>
                            <input type="range"
                                   class="fa-nexus-scalar-randomized__range-input is-max"
                                   min="{{control.min}}"
                                   max="{{control.max}}"
                                   step="{{control.step}}"
                                   value="{{control.randomMax}}"
                                   aria-label="{{control.randomMaxAriaLabel}}"
                                   data-fa-nexus-scalar-random-max-slider="{{control.id}}"
                                   {{#if control.disabled}}disabled{{/if}}>
                          </div>
                        {{else}}
                          <input type="range"
                                 min="{{control.min}}"
                                 max="{{control.max}}"
                                 step="{{control.step}}"
                                 value="{{control.value}}"
                                 aria-label="{{control.ariaLabel}}"
                                 data-fa-nexus-scalar-slider="{{control.id}}"
                                 {{#if control.disabled}}disabled{{/if}}>
                        {{/if}}
                      {{else}}
                        <input type="range"
                               min="{{control.min}}"
                               max="{{control.max}}"
                               step="{{control.step}}"
                               value="{{control.value}}"
                               aria-label="{{control.ariaLabel}}"
                               data-fa-nexus-scalar-slider="{{control.id}}"
                               {{#if control.disabled}}disabled{{/if}}>
                      {{/if}}
                      <button type="button"
                              class="fa-nexus-scalar-randomized__random {{#if control.randomEnabled}}is-active{{/if}}"
                              data-fa-nexus-scalar-random="{{control.id}}"
                              aria-pressed="{{control.randomEnabled}}"
                              aria-label="{{control.randomAria}}"
                              title="{{control.randomTooltip}}"
                              {{#unless control.randomButtonVisible}}hidden{{/unless}}
                              {{#if control.disabled}}disabled{{/if}}>
                        <i class="fas fa-random" aria-hidden="true"></i>
                        <span>{{control.randomLabel}}</span>
                      </button>
                    </div>
                    {{#if control.randomEnabled}}
