                 data-fa-nexus-rotation-display
                 title="{{rotation.display}}"
                 {{#if rotation.disabled}}disabled{{/if}}>
        </div>
        <div class="fa-nexus-rotation__body">
          <input type="range"
                 min="{{rotation.min}}"
                 max="{{rotation.max}}"
                 step="{{rotation.step}}"
                 value="{{rotation.value}}"
                 aria-label="Rotation"
                 data-fa-nexus-rotation-base>
          {{#if rotation.randomButtonVisible}}
            <button type="button"
                    class="fa-nexus-rotation__random {{#if rotation.randomEnabled}}is-active{{/if}}"
                    data-fa-nexus-rotation-random
                    aria-pressed="{{rotation.randomEnabled}}"
                    aria-label="{{rotation.randomTooltip}}"
                    title="{{rotation.randomTooltip}}">
              <i class="fas fa-random" aria-hidden="true"></i>
              <span>{{rotation.randomLabel}}</span>
            </button>
          {{/if}}
        </div>
        {{#if rotation.randomEnabled}}
          <div class="fa-nexus-rotation__strength" data-fa-nexus-rotation-strength-row>
            <span class="fa-nexus-rotation__strength-label">Strength</span>
            <input type="range"
                   min="{{rotation.strengthMin}}"
                   max="{{rotation.strengthMax}}"
                   step="{{rotation.strengthStep}}"
                   value="{{rotation.strength}}"
                   aria-label="Random rotation strength"
                   data-fa-nexus-rotation-strength>
            <input type="number"
                   class="fa-nexus-rotation__strength-value"
                   min="{{rotation.strengthMin}}"
                   max="{{rotation.strengthMax}}"
                   step="{{rotation.strengthStep}}"
                   value="{{rotation.strength}}"
                   inputmode="decimal"
                   data-fa-nexus-rotation-strength-label
                   title="{{rotation.strengthDisplay}}">
          </div>
        {{/if}}
      </div>
      {{/unless}}
    {{/if}}

    {{#if hasCustomToggles}}
      {{#each customToggles as |toggle|}}
        <label class="fa-nexus-tool-options__toggle" title="{{toggle.tooltip}}">
          <input type="checkbox" data-fa-nexus-custom-toggle="{{toggle.id}}" {{#if toggle.enabled}}checked{{/if}} {{#if toggle.disabled}}disabled{{/if}}>
          <span>{{toggle.label}}</span>
        </label>
      {{/each}}
    {{/if}}

  </section>

  {{> faNexusToolOptionsPlaceAs placeAs=placeAs}}

    {{#unless hasActiveTool}}
      <section class="fa-nexus-tool-options__section">
        <div class="fa-nexus-tool-options__empty">
          <span>No tool is currently active.</span>
        </div>
      </section>
    {{/unless}}
  </div>
  {{/if}}

  {{#if hasActiveTool}}
    <footer class="fa-nexus-tool-options__footer">
      {{#if isDeclarative}}
        {{#if declarative.hasFooterSections}}
          <div class="fa-nexus-tool-options__footer-sections">
            {{#each declarative.footerSections as |section|}}
              <section class="fa-nexus-tool-options__footer-section" data-fa-nexus-tool-footer-section="{{section.id}}">
                {{#each section.controls as |control|}}
                  {{#if (eq control.type "action-row")}}
                    <div class="fa-nexus-tool-options__control fa-nexus-editor-actions" data-fa-nexus-editor-actions-root="{{control.id}}">
                      <div class="fa-nexus-texture-tools__actions fa-nexus-editor-actions__buttons">
                        {{#each control.actions as |action|}}
                          <button type="button"
                                  class="fa-nexus-texture-tools__action fa-nexus-editor-actions__action {{#if action.primary}}is-primary{{/if}}"
                                  data-fa-nexus-editor-action="{{action.id}}"
                                  {{#if action.disabled}}disabled{{/if}}
                                  title="{{action.tooltip}}">
                            <span>{{action.label}}</span>
                          </button>
                        {{/each}}
                      </div>
                    </div>
                  {{/if}}

                  {{#if (eq control.type "segmented")}}
                    <div class="fa-nexus-tool-options__control fa-nexus-declarative-segmented"
                         data-fa-nexus-declarative-control="{{control.id}}"
                         {{#if control.handlerId}}data-fa-nexus-segmented-control="{{control.id}}"{{/if}}>
                      <div class="fa-nexus-declarative-segmented__list">
                        {{#each control.options as |option|}}
                          <label class="fa-nexus-declarative-segmented__option {{#if option.enabled}}is-active{{/if}}{{#if option.disabled}} is-disabled{{/if}}" title="{{option.tooltip}}">
                            <input type="{{control.inputType}}"
                                   {{#if control.handlerId}}
                                     data-fa-nexus-segmented-input="{{control.id}}:{{option.id}}"
                                   {{else}}
                                     data-fa-nexus-custom-toggle="{{option.id}}"
                                   {{/if}}
                                   {{#if (eq control.inputType "radio")}}name="fa-nexus-control-{{control.id}}"{{/if}}
                                   {{#if option.enabled}}checked{{/if}}
                                   {{#if option.disabled}}disabled{{/if}}>
                            {{#if option.icon}}
                              <i class="{{option.icon}}" aria-hidden="true"></i>
                            {{/if}}
                            <span>{{option.label}}</span>
                          </label>
                        {{/each}}
                      </div>
                    </div>
                  {{/if}}

                  {{#if (eq control.type "toggle-list")}}
                    <div class="fa-nexus-tool-options__control fa-nexus-declarative-toggle-list" data-fa-nexus-declarative-control="{{control.id}}">
                      <div class="fa-nexus-declarative-segmented__list fa-nexus-declarative-segmented__list--compact">
                        {{#each control.items as |item|}}
                          <label class="fa-nexus-declarative-segmented__option fa-nexus-declarative-segmented__option--compact {{#if item.enabled}}is-active{{/if}}{{#if item.disabled}} is-disabled{{/if}}" title="{{item.tooltip}}">
                            <input type="checkbox"
                                   data-fa-nexus-custom-toggle="{{item.id}}"
                                   {{#if item.enabled}}checked{{/if}}
                                   {{#if item.disabled}}disabled{{/if}}>
                            {{#if item.icon}}
                              <i class="{{item.icon}}" aria-hidden="true"></i>
                            {{/if}}
                            <span>{{item.label}}</span>
                          </label>
                        {{/each}}
                      </div>
                    </div>
                  {{/if}}
                {{/each}}
              </section>
            {{/each}}
          </div>
        {{/if}}
      {{/if}}

      <div class="fa-nexus-tool-options__footer-row fa-nexus-tool-options__footer-session">
        <label class="fa-nexus-tool-options__toggle fa-nexus-tool-options__footer-toggleline" title="Snap new placements to the active scene grid.">
          <input type="checkbox" id="fa-nexus-grid-snap-toggle" {{#if gridSnapEnabled}}checked{{/if}} {{#unless gridSnapAvailable}}disabled{{/unless}}>
          <span>Snap to Grid</span>
        </label>
      {{#if gridSnapResolution.available}}
        <div class="fa-nexus-tool-options__footer-grid fa-nexus-grid-snap" data-fa-nexus-grid-snap-root>
          <div class="fa-nexus-tool-options__footer-grid-header">
            <span class="fa-nexus-tool-options__footer-label">Snap to</span>
            <input type="range"
                   class="fa-nexus-tool-options__footer-density-slider"
                   min="{{gridSnapResolution.min}}"
                   max="{{gridSnapResolution.max}}"
                   step="{{gridSnapResolution.step}}"
                   value="{{gridSnapResolution.value}}"
                   aria-label="Grid snap density"
                   data-fa-nexus-grid-snap-slider
                   {{#if gridSnapResolution.disabled}}disabled{{/if}}>
            <span class="fa-nexus-tool-options__value fa-nexus-tool-options__footer-density"
                  data-fa-nexus-grid-snap-display
                  title="{{gridSnapResolution.display}}">{{gridSnapResolution.display}}</span>
          </div>
        </div>
      {{/if}}
      </div>

    </footer>
  {{/if}}
</div>
