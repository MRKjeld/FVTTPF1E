<div class="fa-nexus-tool-options">
  {{#*inline "faNexusToolOptionsDropShadow"}}
    {{#if control.toggleInSectionHeader}}
    {{else}}
      {{#if control.toggle.available}}
        <label class="fa-nexus-tool-options__toggle" title="{{control.toggle.tooltip}}">
          <input type="checkbox"
                 id="fa-nexus-drop-shadow-toggle"
                 data-fa-nexus-drop-shadow-toggle-input="{{control.id}}"
                 {{#if control.toggle.enabled}}checked{{/if}}
                 {{#if control.toggle.disabled}}disabled{{/if}}>
          <span>{{control.toggle.label}}</span>
        </label>
      {{/if}}
    {{/if}}

    {{#if control.controls.available}}
      <div class="fa-nexus-tool-options__control fa-nexus-drop-shadow {{#if control.controls.collapsed}}is-collapsed{{/if}}" data-fa-nexus-drop-shadow-root="{{control.id}}">
        <div class="fa-nexus-drop-shadow__header">
          {{#if control.controls.collapse.available}}
            <button type="button"
                    class="fa-nexus-drop-shadow__collapse"
                    data-fa-nexus-drop-shadow-toggle
                    aria-expanded="{{#unless control.controls.collapsed}}true{{else}}false{{/unless}}"
                    title="{{#if control.controls.collapsed}}Expand shadow settings{{else}}Collapse shadow settings{{/if}}">
              <i class="fas fa-chevron-down" aria-hidden="true"></i>
            </button>
          {{/if}}
          <span class="fa-nexus-tool-options__label">{{control.controls.label}}</span>
          {{#if control.controls.context.display}}
            <span class="fa-nexus-drop-shadow__elevation" data-fa-nexus-drop-shadow-elevation>Elevation {{control.controls.context.display}}</span>
          {{/if}}
        </div>
        {{#if control.controls.edit.available}}
          <div class="fa-nexus-path-shadow__edit-row" data-fa-nexus-drop-shadow-edit-row>
            <label class="fa-nexus-tool-options__toggle" data-fa-nexus-drop-shadow-edit-root>
              <input type="checkbox"
                     data-fa-nexus-drop-shadow-edit
                     {{#if control.controls.edit.enabled}}checked{{/if}}
                     {{#if control.controls.edit.disabled}}disabled{{/if}}>
              <span>{{control.controls.edit.label}}</span>
            </label>
            {{#if control.controls.edit.reset}}
              <button type="button"
                      class="fa-nexus-path-shadow__reset fa-nexus-path-shadow__edit-reset"
                      data-fa-nexus-drop-shadow-edit-reset
                      title="{{control.controls.edit.reset.tooltip}}"
                      {{#if control.controls.edit.reset.disabled}}disabled{{/if}}>
                {{control.controls.edit.reset.label}}
              </button>
            {{/if}}
          </div>
        {{/if}}
        <div class="fa-nexus-drop-shadow__context-block">
          <div class="fa-nexus-drop-shadow__presets" data-fa-nexus-drop-shadow-presets>
            {{#each control.controls.presets as |preset|}}
              <button type="button"
                      class="fa-nexus-drop-shadow__preset{{#if preset.active}} is-active{{/if}}{{#unless preset.saved}} is-empty{{/unless}}"
                      data-fa-nexus-drop-shadow-preset="{{preset.index}}"
                      aria-pressed="{{#if preset.active}}true{{else}}false{{/if}}"
                      title="{{preset.tooltip}}">
                {{preset.label}}
              </button>
            {{/each}}
            <button type="button"
                    class="fa-nexus-drop-shadow__reset"
                    data-fa-nexus-drop-shadow-reset
                    title="{{control.controls.reset.tooltip}}"
                    {{#if control.controls.reset.disabled}}disabled{{/if}}>
              {{control.controls.reset.label}}
            </button>
          </div>
        </div>
        <div class="fa-nexus-drop-shadow__body" data-fa-nexus-drop-shadow-body>
          <div class="fa-nexus-drop-shadow__group">
            {{#if control.controls.scale}}
            <div class="fa-nexus-texture-offset__row" data-fa-nexus-drop-shadow-scale-row>
              <span class="fa-nexus-texture-offset__axis">{{control.controls.scale.label}}</span>
              <input type="range"
                     min="{{control.controls.scale.min}}"
                     max="{{control.controls.scale.max}}"
                     step="{{control.controls.scale.step}}"
                     value="{{control.controls.scale.value}}"
                     aria-label="{{control.controls.scale.label}}"
                     data-fa-nexus-drop-shadow-scale
                     {{#if control.controls.scale.disabled}}disabled{{/if}}>
              <input type="number"
                     class="fa-nexus-tool-options__value"
                     min="{{control.controls.scale.min}}"
                     max="{{control.controls.scale.max}}"
                     step="{{control.controls.scale.step}}"
                     value="{{control.controls.scale.value}}"
                     inputmode="decimal"
                     data-fa-nexus-drop-shadow-scale-display
                     title="{{control.controls.scale.display}}"
                     {{#if control.controls.scale.disabled}}disabled{{/if}}>
            </div>
            {{/if}}

            {{#if control.controls.offset}}
            {{#if (eq control.controls.offset.mode "polar")}}
            <div class="fa-nexus-drop-shadow__row fa-nexus-drop-shadow__offset" data-fa-nexus-drop-shadow-offset-row>
              <div class="fa-nexus-drop-shadow__row-header">
                <span class="fa-nexus-drop-shadow__row-label">{{control.controls.offset.label}}</span>
                <div class="fa-nexus-drop-shadow__offset-values">
                  <span class="fa-nexus-drop-shadow__offset-value">
                    <span class="fa-nexus-drop-shadow__offset-value-label">Distance</span>
                    <span class="fa-nexus-drop-shadow__offset-value-text" data-fa-nexus-drop-shadow-offset-distance-display>{{control.controls.offset.displayDistance}}</span>
                  </span>
                  {{#if control.controls.offset.offsetMaxHandlerId}}
                  <span class="fa-nexus-drop-shadow__offset-value">
                    <span class="fa-nexus-drop-shadow__offset-value-label">Max</span>
                    <input type="number"
                           class="fa-nexus-tool-options__value fa-nexus-drop-shadow__offset-max-input"
                           min="{{control.controls.offset.maxDistanceMin}}"
                           max="{{control.controls.offset.maxDistanceLimit}}"
                           step="{{control.controls.offset.maxDistanceStep}}"
                           value="{{control.controls.offset.maxDistance}}"
                           inputmode="numeric"
                           aria-label="Maximum shadow offset distance in pixels"
                           data-fa-nexus-drop-shadow-offset-max-display
                           title="{{control.controls.offset.maxDistanceHint}}"
                           {{#if control.controls.offset.disabled}}disabled{{/if}}>
                  </span>
                  {{/if}}
                  <span class="fa-nexus-drop-shadow__offset-value">
                    <span class="fa-nexus-drop-shadow__offset-value-label">Angle</span>
                    <span class="fa-nexus-drop-shadow__offset-value-text" data-fa-nexus-drop-shadow-offset-angle-display>{{control.controls.offset.displayAngle}}</span>
                  </span>
                </div>
              </div>
              <div class="fa-nexus-drop-shadow__offset-control {{#if control.controls.offset.disabled}}is-disabled{{/if}}"
                   data-fa-nexus-drop-shadow-offset-control
                   role="application"
                   aria-label="Shadow offset control"
                   data-max-distance="{{control.controls.offset.maxDistance}}"
                   {{#if control.controls.offset.disabled}}data-disabled="true"{{else}}data-disabled="false"{{/if}}>
                <div class="fa-nexus-drop-shadow__offset-circle" data-fa-nexus-drop-shadow-offset-circle>
                  <div class="fa-nexus-drop-shadow__offset-preview is-empty" data-fa-nexus-drop-shadow-offset-preview>
                    <img class="fa-nexus-drop-shadow__offset-preview-image"
                         data-fa-nexus-drop-shadow-offset-preview-image
                         alt=""
                         draggable="false">
                  </div>
                  <div class="fa-nexus-drop-shadow__offset-crosshair fa-nexus-drop-shadow__offset-crosshair--x"></div>
                  <div class="fa-nexus-drop-shadow__offset-crosshair fa-nexus-drop-shadow__offset-crosshair--y"></div>
                  <div class="fa-nexus-drop-shadow__offset-handle" data-fa-nexus-drop-shadow-offset-handle></div>
                </div>
              </div>
            </div>
            {{else}}
            <div class="fa-nexus-texture-offset__row" data-fa-nexus-drop-shadow-offset-row>
              <span class="fa-nexus-texture-offset__axis">{{control.controls.offset.label}}</span>
              <input type="range"
                     min="{{control.controls.offset.min}}"
                     max="{{control.controls.offset.max}}"
                     step="{{control.controls.offset.step}}"
                     value="{{control.controls.offset.value}}"
                     aria-label="{{control.controls.offset.label}}"
                     data-fa-nexus-drop-shadow-offset
                     {{#if control.controls.offset.disabled}}disabled{{/if}}>
              <input type="number"
                     class="fa-nexus-tool-options__value"
                     min="{{control.controls.offset.min}}"
                     max="{{control.controls.offset.max}}"
                     step="{{control.controls.offset.step}}"
                     value="{{control.controls.offset.value}}"
                     inputmode="decimal"
                     data-fa-nexus-drop-shadow-offset-display
                     title="{{control.controls.offset.display}}"
                     {{#if control.controls.offset.disabled}}disabled{{/if}}>
            </div>
            {{/if}}
            {{/if}}

            <div class="fa-nexus-texture-offset__row" data-fa-nexus-drop-shadow-dilation-row>
              <span class="fa-nexus-texture-offset__axis">{{control.controls.dilation.label}}</span>
              <input type="range"
                     min="{{control.controls.dilation.min}}"
                     max="{{control.controls.dilation.max}}"
                     step="{{control.controls.dilation.step}}"
                     value="{{control.controls.dilation.value}}"
                     aria-label="{{control.controls.dilation.label}}"
                     data-fa-nexus-drop-shadow-dilation
                     {{#if control.controls.dilation.disabled}}disabled{{/if}}>
              <input type="number"
                     class="fa-nexus-tool-options__value"
                     min="{{control.controls.dilation.min}}"
                     max="{{control.controls.dilation.max}}"
                     step="{{control.controls.dilation.step}}"
                     value="{{control.controls.dilation.value}}"
                     inputmode="decimal"
                     data-fa-nexus-drop-shadow-dilation-display
                     title="{{control.controls.dilation.display}}"
                     {{#if control.controls.dilation.disabled}}disabled{{/if}}>
            </div>

            <div class="fa-nexus-texture-offset__row" data-fa-nexus-drop-shadow-alpha-row>
              <span class="fa-nexus-texture-offset__axis">{{control.controls.alpha.label}}</span>
              <input type="range"
                     min="{{control.controls.alpha.min}}"
                     max="{{control.controls.alpha.max}}"
                     step="{{control.controls.alpha.step}}"
                     value="{{control.controls.alpha.value}}"
                     aria-label="{{control.controls.alpha.label}}"
                     data-fa-nexus-drop-shadow-alpha
                     {{#if control.controls.alpha.disabled}}disabled{{/if}}>
              <input type="number"
                     class="fa-nexus-tool-options__value"
                     min="{{control.controls.alpha.min}}"
                     max="{{control.controls.alpha.max}}"
                     step="{{control.controls.alpha.step}}"
                     value="{{control.controls.alpha.value}}"
                     inputmode="decimal"
                     data-fa-nexus-drop-shadow-alpha-display
                     title="{{control.controls.alpha.display}}"
                     {{#if control.controls.alpha.disabled}}disabled{{/if}}>
            </div>

            <div class="fa-nexus-texture-offset__row" data-fa-nexus-drop-shadow-blur-row>
              <span class="fa-nexus-texture-offset__axis">{{control.controls.blur.label}}</span>
              <input type="range"
                     min="{{control.controls.blur.min}}"
                     max="{{control.controls.blur.max}}"
                     step="{{control.controls.blur.step}}"
                     value="{{control.controls.blur.value}}"
                     aria-label="{{control.controls.blur.label}}"
                     data-fa-nexus-drop-shadow-blur
                     {{#if control.controls.blur.disabled}}disabled{{/if}}>
              <input type="number"
                     class="fa-nexus-tool-options__value"
                     min="{{control.controls.blur.min}}"
                     max="{{control.controls.blur.max}}"
                     step="{{control.controls.blur.step}}"
                     value="{{control.controls.blur.value}}"
                     inputmode="decimal"
                     data-fa-nexus-drop-shadow-blur-display
                     title="{{control.controls.blur.display}}"
                     {{#if control.controls.blur.disabled}}disabled{{/if}}>
            </div>
          </div>
        </div>
      </div>
    {{/if}}
  {{/inline}}

  {{#*inline "faNexusToolOptionsPortalControls"}}
    <div class="fa-nexus-tool-options__control fa-nexus-window-controls" data-fa-nexus-portal-root="{{control.id}}">
      <div class="fa-nexus-tool-options__control-header fa-nexus-window-controls__header">
        <span class="fa-nexus-tool-options__label">{{control.title}}</span>
      </div>

      <div class="fa-nexus-window-controls__selection-card">
        <span class="fa-nexus-window-controls__selection-heading">Selection</span>
        <span class="fa-nexus-window-controls__selection-value" data-fa-nexus-portal-selection>{{control.selectionLabel}}</span>
        <span class="fa-nexus-window-controls__selection-hint"
              data-fa-nexus-portal-selection-hint
              {{#unless control.selectionHint}}style="display:none"{{/unless}}>{{control.selectionHint}}</span>
      </div>

      {{#if control.headerActions.length}}
        <div class="fa-nexus-window-controls__header-actions">
          {{#each control.headerActions as |action|}}
            <button type="button"
                    class="fa-nexus-window-controls__header-action {{#if action.primary}}is-primary{{/if}}"
                    data-fa-nexus-portal-action="{{action.id}}"
                    title="{{action.title}}"
                    {{#if action.disabled}}disabled{{/if}}>
              {{#if action.icon}}
                <i class="{{action.icon}}" aria-hidden="true"></i>
              {{/if}}
              <span data-fa-nexus-portal-action-label="{{action.id}}">{{action.label}}</span>
            </button>
          {{/each}}
        </div>
      {{/if}}

      {{#each control.toggleGroups as |group|}}
        <div class="fa-nexus-window-controls__toggles"
             data-fa-nexus-portal-toggle-group="{{group.id}}"
             {{#if (eq group.visible false)}}style="display:none"{{/if}}>
          {{#each group.items as |toggle|}}
            <label class="fa-nexus-tool-options__toggle" title="{{toggle.title}}">
              <input type="checkbox"
                     data-fa-nexus-portal-toggle="{{toggle.id}}"
                     {{#if toggle.checked}}checked{{/if}}
                     {{#if toggle.disabled}}disabled{{/if}}>
              <span>{{toggle.label}}</span>
            </label>
          {{/each}}
        </div>
      {{/each}}

      {{#each control.selectGroups as |group|}}
        <div class="fa-nexus-window-controls__selects"
             data-fa-nexus-portal-select-group="{{group.id}}"
             {{#if (eq group.visible false)}}style="display:none"{{/if}}>
          {{#each group.items as |select|}}
            <label class="fa-nexus-window-controls__select">
              <span class="fa-nexus-tool-options__label">{{select.label}}</span>
              <select data-fa-nexus-portal-select="{{select.id}}" {{#if select.disabled}}disabled{{/if}}>
                {{#each select.options as |option|}}
                  <option value="{{option.value}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>
                {{/each}}
              </select>
            </label>
          {{/each}}
        </div>
      {{/each}}

      {{#if control.color.visible}}
        <div class="fa-nexus-tool-options__section fa-nexus-window-controls__color fa-nexus-tool-section {{#if control.color.collapsed}}is-collapsed{{/if}}"
             data-fa-nexus-portal-color
             data-fa-nexus-portal-section="{{control.color.id}}">
          <div class="fa-nexus-tool-section__heading">
            <button type="button"
                    class="fa-nexus-tool-section__toggle"
                    data-fa-nexus-portal-section-toggle="{{control.color.id}}"
                    aria-expanded="{{#unless control.color.collapsed}}true{{else}}false{{/unless}}"
                    title="{{#if control.color.collapsed}}Expand {{control.color.label}}{{else}}Collapse {{control.color.label}}{{/if}}">
              <i class="fas fa-chevron-down" aria-hidden="true"></i>
              <span class="fa-nexus-tool-section__label">{{control.color.label}}</span>
            </button>
          </div>
          <div class="fa-nexus-tool-section__body fa-nexus-window-controls__color-body"
               data-fa-nexus-portal-section-body="{{control.color.id}}"
               {{#if control.color.collapsed}}aria-hidden="true"{{/if}}>
            {{#if control.color.target.visible}}
              <div class="fa-nexus-declarative-segmented__list fa-nexus-declarative-segmented__list--compact fa-nexus-window-controls__color-targets"
                   data-fa-nexus-portal-color-target-group="{{control.color.target.id}}">
                {{#each control.color.target.items as |item|}}
                  <label class="fa-nexus-declarative-segmented__option fa-nexus-declarative-segmented__option--compact {{#if item.enabled}}is-active{{/if}}{{#if item.disabled}} is-disabled{{/if}}"
                         title="{{item.title}}">
                    <input type="radio"
                           name="{{item.groupName}}"
                           data-fa-nexus-portal-color-target="{{item.id}}"
                           {{#if item.enabled}}checked{{/if}}
                           {{#if item.disabled}}disabled{{/if}}>
                    <span>{{item.label}}</span>
                  </label>
                {{/each}}
              </div>
            {{/if}}
            {{#each control.color.rows as |row|}}
              <div class="fa-nexus-texture-offset__row fa-nexus-window-controls__inline-row">
                <span class="fa-nexus-texture-offset__axis">{{row.label}}</span>
                <input type="range"
                       min="{{row.min}}"
                       max="{{row.max}}"
                       step="{{row.step}}"
                       value="{{row.value}}"
                       title="{{row.hint}}"
                       data-fa-nexus-portal-setting-input="{{row.id}}"
                       {{#if row.disabled}}disabled{{/if}}>
                <input type="number"
                       class="fa-nexus-tool-options__value"
                       min="{{row.min}}"
                       max="{{row.max}}"
                       step="{{row.step}}"
                       value="{{row.value}}"
                       inputmode="decimal"
                       data-fa-nexus-portal-setting-display="{{row.id}}"
                       title="{{row.display}}"
                       {{#if row.disabled}}disabled{{/if}}>
              </div>
            {{/each}}
            {{#if control.color.hint}}
              <p class="fa-nexus-window-controls__hint">{{control.color.hint}}</p>
            {{/if}}
          </div>
        </div>
      {{/if}}

      {{#each control.sections as |section|}}
        <div class="fa-nexus-tool-options__section fa-nexus-window-controls__section fa-nexus-tool-section {{#if section.collapsed}}is-collapsed{{/if}}"
             data-fa-nexus-portal-section="{{section.id}}"
             {{#if (eq section.visible false)}}style="display:none"{{/if}}>
          <div class="fa-nexus-tool-section__heading">
            <button type="button"
                    class="fa-nexus-tool-section__toggle"
                    data-fa-nexus-portal-section-toggle="{{section.id}}"
                    aria-expanded="{{#unless section.collapsed}}true{{else}}false{{/unless}}"
                    title="{{#if section.collapsed}}Expand {{section.label}}{{else}}Collapse {{section.label}}{{/if}}">
              <i class="fas fa-chevron-down" aria-hidden="true"></i>
              <span class="fa-nexus-tool-section__label">{{section.label}}</span>
            </button>
          </div>
          <div class="fa-nexus-tool-section__body fa-nexus-window-controls__section-body"
               data-fa-nexus-portal-section-body="{{section.id}}"
               {{#if section.collapsed}}aria-hidden="true"{{/if}}>
            {{#if section.picker.visible}}
              <div class="fa-nexus-window-controls__row">
                <button type="button"
                        class="fa-nexus-window-controls__pick"
                        data-fa-nexus-portal-action="{{section.picker.pickAction.id}}"
                        title="{{section.picker.pickAction.title}}"
                        {{#if section.picker.pickAction.disabled}}disabled{{/if}}>
                  <i class="{{section.picker.pickAction.icon}}" aria-hidden="true"></i>
                  <span data-fa-nexus-portal-action-label="{{section.picker.pickAction.id}}">{{section.picker.pickAction.label}}</span>
                </button>
                <button type="button"
                        class="fa-nexus-window-controls__clear"
                        data-fa-nexus-portal-action="{{section.picker.clearAction.id}}"
                        title="{{section.picker.clearAction.title}}"
                        {{#if section.picker.clearAction.disabled}}disabled{{/if}}>
                  {{section.picker.clearAction.label}}
                </button>
              </div>
            {{/if}}
            {{#if section.settings}}
              <div class="fa-nexus-window-controls__element-settings"
                   data-fa-nexus-portal-settings="{{section.settings.id}}"
                   {{#if (eq section.settings.visible false)}}style="display:none"{{/if}}>
                {{#each section.settings.rows as |row|}}
                  <div class="fa-nexus-texture-offset__row fa-nexus-window-controls__inline-row">
                    <span class="fa-nexus-texture-offset__axis">{{row.label}}</span>
                    <input type="range"
                           min="{{row.min}}"
                           max="{{row.max}}"
                           step="{{row.step}}"
                           value="{{row.value}}"
                           title="{{row.hint}}"
                           data-fa-nexus-portal-setting-input="{{row.id}}"
                           {{#if row.disabled}}disabled{{/if}}>
                    <input type="number"
                           class="fa-nexus-tool-options__value"
                           min="{{row.min}}"
                           max="{{row.max}}"
                           step="{{row.step}}"
                           value="{{row.value}}"
                           inputmode="decimal"
                           data-fa-nexus-portal-setting-display="{{row.id}}"
                           title="{{row.display}}"
                           {{#if row.disabled}}disabled{{/if}}>
                  </div>
                {{/each}}
              </div>
            {{/if}}
          </div>
        </div>
      {{/each}}
    </div>
  {{/inline}}

  {{#*inline "faNexusToolOptionsPlaceAs"}}
    {{#if placeAs.available}}
      <section class="fa-nexus-tool-options__section fa-nexus-place-as {{#if placeAs.open}}is-open{{/if}}">
        <div class="fa-nexus-place-as__header">
          <span class="fa-nexus-tool-options__label">Place Tokens As</span>
          <button type="button"
                  class="fa-nexus-place-as__filter-button {{#if placeAs.filter.hasExcluded}}has-excluded{{/if}}"
                  data-place-as-filter
                  title="{{placeAs.filter.tooltip}}">
            <i class="fas fa-filter" aria-hidden="true"></i>
            {{#if placeAs.filter.hasExcluded}}
              <span class="fa-nexus-place-as__filter-badge">{{placeAs.filter.excludedCount}}</span>
            {{/if}}
          </button>
        </div>
        <button type="button"
                class="fa-nexus-place-as__selection"
                data-place-as-toggle
                aria-expanded="{{placeAs.open}}"
                aria-controls="fa-nexus-place-as-panel">
          <span class="fa-nexus-place-as__selection-text">
            <span class="fa-nexus-place-as__selection-label">{{placeAs.selectedLabel}}</span>
            {{#if placeAs.selectedSubtitle}}
              <span class="fa-nexus-place-as__selection-subtitle">{{placeAs.selectedSubtitle}}</span>
            {{/if}}
          </span>
          <span class="fa-nexus-place-as__chevron" aria-hidden="true"></span>
        </button>
        {{#if placeAs.open}}
          <div class="fa-nexus-place-as__panel" id="fa-nexus-place-as-panel">
            <div class="fa-nexus-place-as__search-wrapper">
              <input type="search"
                     id="fa-nexus-place-as-search"
                     class="fa-nexus-place-as__search"
                     placeholder="Search actors…"
                     value="{{placeAs.searchValue}}">
            </div>
            <div class="fa-nexus-place-as__list" data-fa-nexus-place-as-list>
              {{#if placeAs.hasOptions}}
                {{#each placeAs.options as |entry|}}
                  {{#if entry.isHeader}}
                    <div class="fa-nexus-place-as__group">{{entry.label}}</div>
                  {{else}}
                    <button type="button"
                            class="fa-nexus-place-as__option {{#if entry.selected}}is-selected{{/if}}"
                            data-place-as-option="{{entry.id}}">
                      <span class="fa-nexus-place-as__option-label">{{entry.label}}</span>
                      {{#if entry.subtitle}}
                        <span class="fa-nexus-place-as__option-subtitle">{{entry.subtitle}}</span>
                      {{/if}}
                    </button>
                  {{/if}}
                {{/each}}
              {{/if}}
            </div>
            {{#if placeAs.emptyMessage}}
              <div class="fa-nexus-place-as__empty">{{placeAs.emptyMessage}}</div>
            {{/if}}
          </div>
        {{/if}}
        {{#if placeAs.actorType.available}}
          <div class="fa-nexus-place-as__actor-type" data-place-as-actor-type-root>
            <label for="fa-nexus-place-as-actor-type" class="fa-nexus-place-as__hp-label">{{placeAs.actorType.label}}</label>
            <select id="fa-nexus-place-as-actor-type"
                    class="fa-nexus-place-as__actor-type-select"
                    data-place-as-actor-type
                    {{#if placeAs.actorType.disabled}}disabled{{/if}}>
