<section id="midi-config-player" class="tab midi-scrollable-list{{#if tab.active}} active{{/if}}"
  data-group="{{tab.group}}" data-tab="{{tab.id}}">
  <div class="midi-qol-box">
    <div class="form-group">
      <label>{{localize "midi-qol.AutoFastForward.Name"}}</label>
      <multi-select name="autoFastForward">
        {{selectOptions fastForwardOptions selected=configSettings.autoFastForward}}
      </multi-select>
    </div>

    <div class="form-group">
      <label>{{localize "midi-qol.AutoAttack.Name"}}</label>
      <input type="checkbox" name="autoRollAttack" data-dtype="Boolean" {{checked configSettings.autoRollAttack}} />
    </div>

    <div class="form-group">
      <label>{{localize "midi-qol.ConsumeResource.Name"}}</label>
      <select name="consumeResource" data-dtype="String">
        {{selectOptions ConsumeResourceOptions selected=configSettings.consumeResource localize=true}}
      </select>
    </div>

    <div class="notes midi-qol-faint">{{{localize "midi-qol.ConsumeResource.Hint"}}}</div>

    <div class="form-group">
      <label>{{localize "midi-qol.ConfirmAmmunition.Name"}}</label>
      <input type="checkbox" name="confirmAmmunition" data-dtype="Boolean" {{checked
        configSettings.confirmAmmunition}} />
    </div>

    <div class="form-group">
      <label>{{localize "midi-qol.RequireAmmunition.Name"}}</label>
      <input type="checkbox" name="playerRequireAmmunition" data-dtype="Boolean" {{checked
        configSettings.playerRequireAmmunition}} />
    </div>

    <div class="form-group">
      <label>{{localize "midi-qol.AutoDamage.Name"}}</label>
      <select name="autoRollDamage" data-dtype="String">
        {{selectOptions autoRollDamageOptions selected=configSettings.autoRollDamage localize=true}}
      </select>
    </div>

    <div class="form-group">
      <label>{{localize "midi-qol.RemoveButtons.Name"}}</label>
      <select name="removeButtons" data-dtype="String">
        {{selectOptions removeButtonsOptions selected=configSettings.removeButtons localize=true}}
      </select>
    </div>
  </div>
</section>